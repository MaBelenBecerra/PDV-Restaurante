        "parameters": [
          { "name": "companyCen", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "unitCen", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateUnitContractRequest" } } }
        },
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UnitContractDto" } } } }
        }
      }
    },
