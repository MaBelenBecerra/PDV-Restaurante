      "CompanyContractDto": { "type": "object", "properties": { "companyCen": { "type": "string" }, "name": { "type": "string" }, "isActive": { "type": "boolean" } } },
      "CompanyLookupContractDto": { "type": "object", "properties": { "companyId": { "type": "integer" }, "companyCen": { "type": "string" }, "name": { "type": "string" } } },
      "CreateCategoryContractRequest": { "type": "object", "properties": { "name": { "type": "string" }, "description": { "type": "string", "nullable": true } } },
      "CreateProductContractRequest": { "type": "object", "properties": { "sku": { "type": "string" }, "name": { "type": "string" }, "description": { "type": "string", "nullable": true }, "categoryCen": { "type": "string" }, "unitCen": { "type": "string" }, "salePrice": { "type": "number" }, "costPrice": { "type": "number", "nullable": true }, "reorderLevel": { "type": "number" }, "stationCode": { "type": "string", "nullable": true } } },
      "CreateProductContractResponse": { "type": "object", "properties": { "productCen": { "type": "string" }, "sku": { "type": "string" }, "name": { "type": "string" }, "status": { "type": "string" }, "initialStock": { "type": "number" } } },
      "CreateUnitContractRequest": { "type": "object", "properties": { "name": { "type": "string" }, "abbreviation": { "type": "string", "nullable": true } } },
      "InventoryDashboardContractDto": { "type": "object", "properties": { "companyCen": { "type": "string" }, "totalProducts": { "type": "integer" }, "totalStockQuantity": { "type": "number" }, "lowStockCount": { "type": "integer" }, "outOfStockCount": { "type": "integer" } } },
      "ProductContractDto": { "type": "object", "properties": { "productCen": { "type": "string" }, "sku": { "type": "string" }, "name": { "type": "string" }, "description": { "type": "string", "nullable": true }, "categoryCen": { "type": "string" }, "categoryName": { "type": "string" }, "unitCen": { "type": "string" }, "unitName": { "type": "string" }, "salePrice": { "type": "number" }, "costPrice": { "type": "number", "nullable": true }, "reorderLevel": { "type": "number" }, "status": { "type": "string" }, "stationCode": { "type": "string", "nullable": true } } },
      "ProductLookupContractRequest": { "type": "object", "properties": { "productCens": { "type": "array", "items": { "type": "string" } } } },
      "SellableProductContractDto": { "type": "object", "properties": { "productCen": { "type": "string" }, "name": { "type": "string" }, "categoryCen": { "type": "string" }, "categoryName": { "type": "string" }, "salePrice": { "type": "number" }, "availableQuantity": { "type": "number" }, "isAvailable": { "type": "boolean" }, "stationCode": { "type": "string", "nullable": true } } },
      "StockItemContractDto": { "type": "object", "properties": { "productCen": { "type": "string" }, "productName": { "type": "string" }, "warehouseCen": { "type": "string" }, "warehouseName": { "type": "string" }, "availableQuantity": { "type": "number" }, "reservedQuantity": { "type": "number" }, "unitName": { "type": "string" }, "reorderLevel": { "type": "number" }, "isLowStock": { "type": "boolean" } } },
      "StockValidationContractRequest": { "type": "object", "properties": { "warehouseCen": { "type": "string" }, "source": { "type": "string" }, "referenceCen": { "type": "string", "nullable": true }, "items": { "type": "array", "items": { "$ref": "#/components/schemas/StockValidationItemContractDto" } } } },
      "StockValidationContractResponse": { "type": "object", "properties": { "isValid": { "type": "boolean" }, "requirements": { "type": "array", "items": { "$ref": "#/components/schemas/StockRequirementContractDto" } } } },
      "StockValidationItemContractDto": { "type": "object", "properties": { "productCen": { "type": "string" }, "quantity": { "type": "number" } } },
      "StockRequirementContractDto": { "type": "object", "properties": { "productCen": { "type": "string" }, "productName": { "type": "string" }, "warehouseCen": { "type": "string" }, "requestedQuantity": { "type": "number" }, "availableQuantity": { "type": "number" }, "missingQuantity": { "type": "number" }, "unitName": { "type": "string" }, "reason": { "type": "string" } } },
      "UnitContractDto": { "type": "object", "properties": { "unitCen": { "type": "string" }, "name": { "type": "string" }, "abbreviation": { "type": "string", "nullable": true }, "isActive": { "type": "boolean" } } },
      "WarehouseContractDto": { "type": "object", "properties": { "warehouseCen": { "type": "string" }, "name": { "type": "string" }, "isActive": { "type": "boolean" } } },
      "CreateWarehouseContractRequest": { "type": "object", "properties": { "name": { "type": "string" }, "isActive": { "type": "boolean" } } },
      "UpdateCompanyContractRequest": { "type": "object", "properties": { "name": { "type": "string" }, "isActive": { "type": "boolean" } } },
      "CreateCompanyContractRequest": { "type": "object", "properties": { "name": { "type": "string" }, "isActive": { "type": "boolean" } } },
      "UpdateProductContractRequest": { "type": "object", "properties": { "sku": { "type": "string" }, "name": { "type": "string" }, "description": { "type": "string", "nullable": true }, "categoryCen": { "type": "string" }, "unitCen": { "type": "string" }, "salePrice": { "type": "number" }, "costPrice": { "type": "number", "nullable": true }, "reorderLevel": { "type": "number" }, "stationCode": { "type": "string", "nullable": true } } },
      "UpdateProductStatusContractRequest": { "type": "object", "properties": { "status": { "type": "string" }, "reason": { "type": "string", "nullable": true } } },
      "InventoryDocumentContractDto": { "type": "object", "properties": { "documentCen": { "type": "string" }, "documentType": { "type": "string" }, "status": { "type": "string" }, "title": { "type": "string" }, "createdAt": { "type": "string", "format": "date-time" }, "totalItems": { "type": "integer" } } },
      "InventoryDocumentContractRequest": { "type": "object", "properties": { "documentType": { "type": "string" }, "warehouseCen": { "type": "string" }, "reason": { "type": "string", "nullable": true }, "externalReference": { "type": "string", "nullable": true }, "lines": { "type": "array", "items": { "type": "object", "properties": { "productCen": { "type": "string" }, "quantity": { "type": "number" } } } } } },
