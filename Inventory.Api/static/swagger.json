{
  "openapi": "3.0.3",
  "info": {
    "title": "Inventory API",
    "description": "Microservicio de catálogo de productos, categorías, unidades de medida y gestión de stock del sistema PDV Restaurante.",
    "version": "1.1.0"
  },
  "paths": {
    "/api/inventory/companies": {
      "get": {
        "tags": ["InventoryCompaniesContract"],
        "summary": "Lista empresas del contrato de inventario",
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/CompanyContractDto" } } } }
          }
        }
      },
      "post": {
        "tags": ["InventoryCompaniesContract"],
        "summary": "Crea una empresa",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateCompanyContractRequest" } } }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CompanyContractDto" } } }
          }
        }
      }
    },
    "/api/inventory/companies/{companyCen}": {
      "get": {
        "tags": ["InventoryCompaniesContract"],
        "summary": "Obtiene una empresa por CEN",
        "parameters": [{ "name": "companyCen", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CompanyLookupContractDto" } } } }
        }
      },
      "put": {
        "tags": ["InventoryCompaniesContract"],
        "summary": "Actualiza una empresa",
        "parameters": [{ "name": "companyCen", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpdateCompanyContractRequest" } } }
        },
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CompanyContractDto" } } } }
        }
      }
    },
