{
  "openapi": "3.0.3",
  "info": {
    "title": "Sales API",
    "description": "Microservicio de ventas, facturación, comensales, KDS (cocina/bar) y dashboard analítico del sistema PDV Restaurante.",
    "version": "1.1.0"
  },
  "paths": {
    "/api/sales/companies/{companyCen}/tickets": {
      "get": {
        "tags": ["TicketsContract"],
        "summary": "Lista tickets del dia",
        "parameters": [{ "name": "companyCen", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/TicketContractResponse" } } } } }
        }
      },
      "post": {
        "tags": ["TicketsContract"],
        "summary": "Crea un ticket",
        "parameters": [{ "name": "companyCen", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateTicketContractRequest" } } } },
        "responses": {
          "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TicketContractResponse" } } } }
        }
      }
    },
    "/api/sales/companies/{companyCen}/tickets/{ticketCen}/items": {
      "get": {
        "tags": ["TicketsContract"],
        "summary": "Lista items de un ticket",
        "parameters": [{ "name": "companyCen", "in": "path", "required": true, "schema": { "type": "string" } }, { "name": "ticketCen", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/TicketItemContractResponse" } } } } }
        }
      },
      "post": {
        "tags": ["TicketsContract"],
        "summary": "Agrega un item a un ticket",
        "parameters": [{ "name": "companyCen", "in": "path", "required": true, "schema": { "type": "string" } }, { "name": "ticketCen", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateTicketItemContractRequest" } } } },
        "responses": {
          "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TicketItemContractResponse" } } } }
        }
      }
    },
    "/api/sales/companies/{companyCen}/tickets/{ticketCen}/items/{ticketItemCen}": {
      "patch": {
        "tags": ["TicketsContract"],
        "summary": "Actualiza un item de ticket",
        "parameters": [{ "name": "companyCen", "in": "path", "required": true, "schema": { "type": "string" } }, { "name": "ticketCen", "in": "path", "required": true, "schema": { "type": "string" } }, { "name": "ticketItemCen", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpdateTicketItemContractRequest" } } } },
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TicketItemContractResponse" } } } }
        }
      }
    },
    "/api/sales/companies/{companyCen}/tickets/{ticketCen}/payment": {
      "post": {
        "tags": ["TicketPaymentsContract"],
        "summary": "Procesa el pago de un ticket",
        "parameters": [{ "name": "companyCen", "in": "path", "required": true, "schema": { "type": "string" } }, { "name": "ticketCen", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PayTicketContractRequest" } } } },
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PayTicketContractResponse" } } } }
        }
      }
    },
    "/api/sales/companies/{companyCen}/tickets/{ticketCen}/cancel": {
      "post": {
        "tags": ["TicketsContract"],
        "summary": "Cancela un ticket",
        "parameters": [{ "name": "companyCen", "in": "path", "required": true, "schema": { "type": "string" } }, { "name": "ticketCen", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CancelTicketContractResponse" } } } }
        }
      }
    },
    "/api/sales/companies/{companyCen}/dashboard/daily-sales": {
      "get": {
        "tags": ["DashboardContract"],
        "summary": "Obtiene ventas diarias",
        "parameters": [{ "name": "companyCen", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DailySalesDashboardDto" } } } }
        }
      }
    },
    "/api/sales/companies/{companyCen}/dashboard/monthly": {
      "get": {
        "tags": ["DashboardContract"],
        "summary": "Obtiene comparativa mensual de ventas",
        "parameters": [{ "name": "companyCen", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MonthlySalesDashboardDto" } } } }
        }
      }
    },
    "/api/sales/companies/{companyCen}/kds/teams": {
      "get": {
        "tags": ["KdsContract"],
        "summary": "Lista equipos KDS",
        "parameters": [{ "name": "companyCen", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/KdsTeamContractResponse" } } } } }
        }
      },
      "post": {
        "tags": ["KdsContract"],
        "summary": "Crea un equipo KDS",
        "parameters": [{ "name": "companyCen", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateKdsTeamContractRequest" } } } },
        "responses": {
          "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/KdsTeamContractResponse" } } } }
        }
      }
    },
    "/api/sales/companies/{companyCen}/kds/teams/{teamCen}/items": {
      "get": {
        "tags": ["KdsContract"],
        "summary": "Lista items KDS por equipo",
        "parameters": [{ "name": "companyCen", "in": "path", "required": true, "schema": { "type": "string" } }, { "name": "teamCen", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/KdsItemContractResponse" } } } } }
        }
      }
    },
    "/api/sales/companies/{companyCen}/kds/items/{ticketItemCen}/status": {
      "patch": {
        "tags": ["KdsContract"],
        "summary": "Actualiza estado de item KDS",
        "parameters": [{ "name": "companyCen", "in": "path", "required": true, "schema": { "type": "string" } }, { "name": "ticketItemCen", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpdateKdsItemStatusContractRequest" } } } },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/sales/companies/{companyCen}/waiters": {
      "get": {
        "tags": ["WaitersContract"],
        "summary": "Lista meseros por empresa",
        "parameters": [{ "name": "companyCen", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/WaiterContractResponse" } } } } }
        }
      },
      "post": {
        "tags": ["WaitersContract"],
        "summary": "Crea un mesero",
        "parameters": [{ "name": "companyCen", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateWaiterContractRequest" } } } },
        "responses": {
          "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WaiterContractResponse" } } } }
        }
      }
    },
    "/api/sales/payment-methods": {
      "get": {
        "tags": ["PaymentMethodsContract"],
        "summary": "Lista metodos de pago",
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/PaymentMethodContractResponse" } } } } }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TicketContractResponse": { "type": "object", "properties": { "ticketCen": { "type": "string" }, "dailyNumber": { "type": "integer" }, "status": { "type": "string" }, "createdAt": { "type": "string" }, "waiterCen": { "type": "string", "nullable": true }, "companyCen": { "type": "string", "nullable": true }, "taxAmount": { "type": "number" } } },
      "CreateTicketContractRequest": { "type": "object", "properties": { "waiterCen": { "type": "string", "nullable": true } } },
      "TicketItemContractResponse": { "type": "object", "properties": { "ticketItemCen": { "type": "string" }, "productCen": { "type": "string" }, "productName": { "type": "string" }, "quantity": { "type": "integer" }, "unitPrice": { "type": "number" }, "note": { "type": "string", "nullable": true }, "status": { "type": "string" } } },
      "CreateTicketItemContractRequest": { "type": "object", "properties": { "productCen": { "type": "string" }, "quantity": { "type": "integer" }, "note": { "type": "string", "nullable": true } } },
      "UpdateTicketItemContractRequest": { "type": "object", "properties": { "quantity": { "type": "integer" }, "note": { "type": "string", "nullable": true } } },
      "PayTicketContractRequest": { "type": "object", "properties": { "paymentMethodCode": { "type": "string" } } },
      "PayTicketContractResponse": { "type": "object", "properties": { "saleCen": { "type": "string" }, "ticketCen": { "type": "string" }, "status": { "type": "string" }, "subtotal": { "type": "number" }, "taxAmount": { "type": "number" }, "total": { "type": "number" } } },
      "CancelTicketContractResponse": { "type": "object", "properties": { "ticketCen": { "type": "string" }, "status": { "type": "string" } } },
      "DailySalesDashboardDto": { "type": "object", "properties": { "totalSales": { "type": "number" }, "ticketsCount": { "type": "integer" }, "averageTicket": { "type": "number" } } },
      "MonthlySalesDashboardDto": { "type": "object", "properties": { "currentMonthTotal": { "type": "number" }, "previousMonthTotal": { "type": "number" }, "growthPercentage": { "type": "number" } } },
      "KdsTeamContractResponse": { "type": "object", "properties": { "teamCen": { "type": "string" }, "name": { "type": "string" } } },
      "CreateKdsTeamContractRequest": { "type": "object", "properties": { "name": { "type": "string" } } },
      "KdsItemContractResponse": { "type": "object", "properties": { "ticketItemCen": { "type": "string" }, "ticketCen": { "type": "string" }, "productCen": { "type": "string" }, "productName": { "type": "string" }, "quantity": { "type": "integer" }, "status": { "type": "string" }, "note": { "type": "string", "nullable": true }, "createdAt": { "type": "string" } } },
      "UpdateKdsItemStatusContractRequest": { "type": "object", "properties": { "status": { "type": "string" } } },
      "WaiterContractResponse": { "type": "object", "properties": { "waiterCen": { "type": "string" }, "name": { "type": "string" } } },
      "CreateWaiterContractRequest": { "type": "object", "properties": { "name": { "type": "string" } } },
      "PaymentMethodContractResponse": { "type": "object", "properties": { "paymentMethodCode": { "type": "string" }, "name": { "type": "string" }, "isActive": { "type": "boolean" } } }
    }
  }
}
